    "import sys\n",
    "\n",
    "specific_games = [\n",
    "    \"europe_uefa-champions-league/2016-2017/2016-10-19 - 21-45 Barcelona 4 - 0 Manchester City\",\n",
    "    \"europe_uefa-champions-league/2016-2017/2016-09-28 - 21-45 Napoli 4 - 2 Benfica\",\n",
    "    \"europe_uefa-champions-league/2016-2017/2017-05-02 - 21-45 Real Madrid 3 - 0 Atl. Madrid\",\n",
    "]\n",
    "\n",
    "# Download each requested game and then stop the cell to avoid running the remainder.\n",
    "for specific_game in specific_games:\n",
    "    matches = [(s, g) for s, g in get_ucl_games(SPLITS) if g == specific_game]\n",
    "    if not matches:\n",
    "        print(f\"Jogo não encontrado: {specific_game}\")\n",
    "        continue\n",
    "    split, game = matches[0]\n",
    "    print(f\"Baixando apenas: {split}: {game}\")\n",
    "    myDownloader = SoccerNetDownloader(LocalDirectory=LOCAL_DIR)\n",
    "    myDownloader.password = PASSWORD\n",
    "    myDownloader.downloadGame(files=[\"1_720p.mkv\", \"2_720p.mkv\"], game=game, spl=split, verbose=True)\n",
    "\n",
    "sys.exit(0)\n",
